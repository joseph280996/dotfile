{
	"$schema": "https://opencode.ai/config.json",
	"model": "github-copilot/claude-sonnet-4.6",
	"plugin": ["@plannotator/opencode@latest", "@tarquinen/opencode-dcp@latest", "superpowers@git+https://github.com/obra/superpowers.git"],
	"mcp": {
		"git": {
			"type": "local",
			"command": ["uvx", "mcp-server-git"]
		},
		"mcp-atlassian": {
			"type": "local",
			"command": ["uvx", "mcp-atlassian"],
			"enabled": true,
			"environment": {
				"CONFLUENCE_API_TOKEN": "{env:ATLASSIAN_CONFLUENCE_API_KEY}",
				"CONFLUENCE_URL": "{env:ATLASSIAN_CONFLUENCE_URL}",
				"CONFLUENCE_USERNAME": "{env:ATLASSIAN_USERNAME}",
				"JIRA_API_TOKEN": "{env:ATLASSIAN_JIRA_API_KEY}",
				"JIRA_URL": "{env:ATLASSIAN_JIRA_URL}",
				"JIRA_USERNAME": "{env:ATLASSIAN_USERNAME}"
			}
		},
		"memory": {
			"type": "local",
			"command": ["npx", "-y", "@modelcontextprotocol/server-memory"]
		},
		"playwright": {
			"type": "local",
			"command": ["npx", "@playwright/mcp@latest"]
		},
		"sequentialthinking": {
			"type": "local",
			"command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
		}
	}
}
